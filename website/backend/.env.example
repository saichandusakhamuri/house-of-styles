# Server Configuration
NODE_ENV=development
PORT=5001
SERVER_URL=http://localhost:5001

# MongoDB Configuration (required)
# The server will not start without MongoDB. Use MONGODB_ATLAS_URI on Render/Atlas.
MONGODB_URI=mongodb://localhost:27017/house-of-styles
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/house-of-styles?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this_in_production
JWT_REFRESH_EXPIRE=30d

# Stripe Configuration
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# CORS Configuration
# Local dev examples:
# CORS_ORIGIN=http://localhost:8000,http://127.0.0.1:8000
# Render example:
# CORS_ORIGIN=https://house-of-styles-frontend.onrender.com
CORS_ORIGIN=http://localhost:8000,http://127.0.0.1:8000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_DIR=./logs

# Email Configuration (optional, for future)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Admin Configuration
ADMIN_EMAIL=admin@houseofstyles.com
ADMIN_PASSWORD=changeme

# Frontend URL (for redirects and CORS)
FRONTEND_URL=http://localhost:8000
